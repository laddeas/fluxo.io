{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@datafusion-ai/source"],
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "baseUrl": ".",
    "paths": {
      "@datafusion-ai/shared-types": ["packages/shared-types/src/index.ts"],
      "@datafusion-ai/shared-utils": ["packages/shared-utils/src/index.ts"],
      "@datafusion-ai/database": ["packages/database/src/index.ts"],
      "@datafusion-ai/connector-sdk": ["packages/connector-sdk/src/index.ts"]
    }
  }
}
